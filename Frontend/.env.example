# Frontend Environment Variables

# API Base URL
# For development (with vite proxy): leave empty or use /api
# For production (direct API calls): set to your backend URL
# Example: https://your-backend.onrender.com
VITE_API_BASE_URL=

# Optional: Gemini API Key
# Can be injected at build time if needed
# VITE_GEMINI_API_KEY=your_gemini_key
